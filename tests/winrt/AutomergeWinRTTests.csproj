<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.22621.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
    <Platforms>x64</Platforms>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!--
      CsWinRT: point at our built .winmd for projection generation.
      The generated C# bindings are placed in the obj folder automatically.
    -->
    <CsWinRTIncludes>Automerge.Windows</CsWinRTIncludes>
    <CsWinRTGeneratedFilesDir>$(IntermediateOutputPath)Generated Files\</CsWinRTGeneratedFilesDir>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.*" />
    <PackageReference Include="xunit" Version="2.*" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="coverlet.collector" Version="6.*">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <!--
      Microsoft.Windows.CsWinRT generates C# projections from the WinMD at build time.
      The version must match the cppwinrt SDK version used to build the DLL.
    -->
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.*" />
  </ItemGroup>

  <!--
    Reference the built .winmd as metadata so CsWinRT can generate the projection.
    The DLLs (Automerge.Windows.dll, automerge_core.dll) are copied to the output dir
    so the activation factory can load them at test runtime.
  -->
  <ItemGroup>
    <!-- CsWinRT inputs: feed the raw winmd to the projection generator -->
    <CsWinRTInputs Include="..\..\build-winrt\release\Automerge.Windows.winmd" />
  </ItemGroup>

  <!-- Copy native DLLs to the test output directory -->
  <ItemGroup>
    <Content Include="..\..\build-winrt\release\Automerge.Windows.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\..\rust-core\target\release\automerge_core.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

</Project>
