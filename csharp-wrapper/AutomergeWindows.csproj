<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <AssemblyName>AutomergeWindows</AssemblyName>
    <RootNamespace>Automerge.Windows</RootNamespace>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <Platforms>x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <PropertyGroup>
    <UseWindowsDesktopSdk>false</UseWindowsDesktopSdk>
  </PropertyGroup>

  <!-- WinRT projection, generated from the WinRT component .winmd -->
  <!-- Uncomment when the WinRT component is built:
  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.*" />
  </ItemGroup>
  <ItemGroup>
    <CsWinRTInputs Include="..\winrt-component\bin\Release\net9.0\Automerge.Windows.winmd" />
  </ItemGroup>
  -->

</Project>
