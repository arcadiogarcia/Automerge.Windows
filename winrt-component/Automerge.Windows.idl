// Automerge.Windows.idl
// WinRT projection for the Automerge CRDT library.
// Targets: Windows App SDK (WinUI 3) and Windows 10+

import "Windows.Foundation.idl";
import "Windows.Storage.Streams.idl";

namespace Automerge.Windows
{
    // ─── Document ─────────────────────────────────────────────────────────────

    /// WinRT projection of an Automerge document.
    ///
    /// Object IDs: pass an empty string for the document root; nested objects
    /// return their ID as a String from PutObject / InsertObject.
    ///
    /// Scalar JSON: methods that take scalarJson expect a JSON-encoded scalar:
    ///   "{\"hello\"}", "42", "true", "null".
    runtimeclass Document
    {
        /// Create a new empty document.
        Document();

        // ─── Persistence ─────────────────────────────────────────────────

        Windows.Storage.Streams.IBuffer Save();
        static Document Load(Windows.Storage.Streams.IBuffer data);

        /// Save only changes since the last Save / SaveIncremental call.
        Windows.Storage.Streams.IBuffer SaveIncremental();

        // ─── Fork ────────────────────────────────────────────────────────

        /// Fork (clone) the document, producing an independent copy.
        Document Fork();

        // ─── Heads ───────────────────────────────────────────────────────

        Windows.Storage.Streams.IBuffer GetHeads();

        // ─── Changes ─────────────────────────────────────────────────────

        Windows.Storage.Streams.IBuffer GetChanges(Windows.Storage.Streams.IBuffer heads);
        void ApplyChanges(Windows.Storage.Streams.IBuffer changes);

        // ─── Merge ───────────────────────────────────────────────────────

        void Merge(Document other);

        // ─── Actor ───────────────────────────────────────────────────────

        Windows.Storage.Streams.IBuffer GetActorId();
        void SetActorId(Windows.Storage.Streams.IBuffer actorId);

        // ─── Read ────────────────────────────────────────────────────────

        /// Read a value by JSON-array path (legacy; serialises whole doc).
        String GetValue(String pathJson);

        /// Get a single value from a map object by key. Returns JSON.
        String Get(String objId, String key);

        /// Get a single value from a list/text object by 0-based index. Returns JSON.
        String GetIdx(String objId, Int32 index);

        /// Get all map keys as a JSON array string.
        String GetKeysJson(String objId);

        /// Get the number of items in an object.
        Int32 GetLength(String objId);

        /// Get the text content of a text CRDT object.
        String GetText(String objId);

        /// Get all concurrent values for a key (conflict detection). Returns JSON array.
        String GetAllJson(String objId, String key);

        // ─── Write ───────────────────────────────────────────────────────

        /// Set scalar key-value pairs from a JSON object (legacy).
        void PutJsonRoot(String jsonObj);

        /// Set a scalar value in a map object.
        void Put(String objId, String key, String scalarJson);

        /// Set a scalar value in a list object at an index.
        void PutIdx(String objId, Int32 index, String scalarJson);

        /// Create a nested object. objType: "map", "list", or "text".
        /// Returns the new object's ID.
        String PutObject(String objId, String key, String objType);

        /// Delete a key from a map object.
        void Delete(String objId, String key);

        // ─── List operations ─────────────────────────────────────────────

        /// Insert a scalar into a list. Pass Int32.MaxValue to append.
        void Insert(String listObjId, Int32 index, String scalarJson);

        /// Insert a nested object into a list. Returns new object ID.
        String InsertObject(String listObjId, Int32 index, String objType);

        /// Delete the element at an index from a list.
        void DeleteAt(String listObjId, Int32 index);

        // ─── Counter ─────────────────────────────────────────────────────

        void PutCounter(String objId, String key, Int64 initialValue);
        void Increment(String objId, String key, Int64 delta);

        // ─── Text CRDT ───────────────────────────────────────────────────

        void SpliceText(String textObjId, Int32 start, Int32 deleteCount, String text);

        // ─── Commit ──────────────────────────────────────────────────────

        void Commit(String message, Int64 timestamp);

        // ─── Diff / patches ──────────────────────────────────────────────

        String DiffIncremental();

        // ─── New APIs: closing gap with JS @automerge/automerge ──────────

        /// Get ALL changes as concatenated bytes.
        Windows.Storage.Streams.IBuffer GetAllChanges();

        /// Get the last locally-made change as bytes.
        Windows.Storage.Streams.IBuffer GetLastLocalChange();

        /// Get missing dependency hashes needed to reach `heads`.
        Windows.Storage.Streams.IBuffer GetMissingDeps(Windows.Storage.Streams.IBuffer heads);

        /// Create an empty change.
        void EmptyChange(String message, Int64 timestamp);

        /// Save changes since `heads`.
        Windows.Storage.Streams.IBuffer SaveAfter(Windows.Storage.Streams.IBuffer heads);

        /// Load incremental changes into this document.
        void LoadIncremental(Windows.Storage.Streams.IBuffer data);

        /// Fork at specific heads (historical snapshot).
        Document ForkAt(Windows.Storage.Streams.IBuffer heads);

        /// Get object type ("map", "list", "text") as JSON string.
        String ObjectType(String objId);

        /// Diff between two heads. Returns JSON patch array.
        String Diff(Windows.Storage.Streams.IBuffer beforeHeads, Windows.Storage.Streams.IBuffer afterHeads);

        /// Update text by diffing (JS updateText).
        void UpdateText(String textObjId, String newText);

        /// Add a rich text mark. expand: 0=none, 1=before, 2=after, 3=both.
        void Mark(String textObjId, Int32 start, Int32 end,
                  String name, String valueJson, UInt8 expand);

        /// Remove a mark.
        void Unmark(String textObjId, String name, Int32 start, Int32 end, UInt8 expand);

        /// Get all marks. Returns JSON array.
        String GetMarks(String textObjId);

        /// Get marks at specific heads. Returns JSON array.
        String GetMarksAt(String textObjId, Windows.Storage.Streams.IBuffer heads);

        /// Get a cursor for a text position.
        String GetCursor(String textObjId, Int32 position);

        /// Resolve a cursor to a position.
        Int32 GetCursorPosition(String textObjId, String cursor);

        /// Get rich text spans. Returns JSON array.
        String GetSpans(String textObjId);

        /// Get document statistics as JSON.
        String GetStats();

        /// Get map entries in a key range. Empty string = unbounded.
        String MapRange(String objId, String start, String end);

        /// Get list entries in an index range.
        String ListRange(String objId, Int32 start, Int32 end);
    }

    // ─── SyncState ────────────────────────────────────────────────────────────

    runtimeclass SyncState
    {
        SyncState();

        Windows.Storage.Streams.IBuffer GenerateSyncMessage(Document doc);
        void ReceiveSyncMessage(Document doc,
                                Windows.Storage.Streams.IBuffer message);

        Windows.Storage.Streams.IBuffer Save();
        static SyncState Load(Windows.Storage.Streams.IBuffer data);
    }

    // ─── RepoSyncSession ──────────────────────────────────────────────────────

    /// WebSocket sync session compatible with the automerge-repo v1 protocol.
    ///
    /// <para>
    /// Connects to a sync server (e.g. wss://sync.automerge.org), performs the
    /// join/peer handshake, then exchanges automerge sync-protocol messages
    /// until convergence or cancellation.
    /// </para>
    runtimeclass RepoSyncSession
    {
        /// Create a session using a randomly-generated peer ID.
        RepoSyncSession(String serverUrl, String documentId);

        /// Create a session with an explicit stable peer ID.
        RepoSyncSession(String serverUrl, String documentId, String peerId);

        /// Connect and run the sync loop until the IAsyncAction is cancelled.
        Windows.Foundation.IAsyncAction RunAsync(Document doc, SyncState syncState);

        /// Connect, sync to convergence (2-second idle), then disconnect.
        static Windows.Foundation.IAsyncAction SyncOnceAsync(
            String serverUrl,
            String documentId,
            Document doc,
            SyncState syncState);

        /// Gracefully close the WebSocket connection.
        Windows.Foundation.IAsyncAction CloseAsync();

        /// Raised each time RunAsync or SyncOnceAsync applies an incoming
        /// remote sync frame to the document.  Subscribe to drive reactive UI
        /// updates, call DiffIncremental(), or persist to disk — without polling.
        event Windows.Foundation.TypedEventHandler<RepoSyncSession, Object> RemoteChange;
    }
}
